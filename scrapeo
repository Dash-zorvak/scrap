#!/bin/bash
DIR="$(cd "$(dirname "$0")" && pwd)"
source "$DIR/venv/bin/activate"
if [ "$1" = "estimate" ]; then
    target="${2:-20000}"
    exec python3 "$DIR/src/analyzer/estimation.py" "$target"
fi
if [ "$1" = "phase3" ]; then
    shift
    exec python3 -m src.main phase3 "$@"
fi
exec python3 -m src.main "$@"
