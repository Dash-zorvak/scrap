# === FACEBOOK PAGE ===
FB_PAGE_URL=https://www.facebook.com/SantaAnaAlcaldia
FB_PAGE_NAME=Santa Ana Alcaldía

# === FACEBOOK LOGIN (necesario para Playwright) ===
FB_EMAIL=
FB_PASSWORD=

# === TIKTOK ===
TT_USERNAME=alcaldiasa

# === SCRAPING CONFIG ===
REQUESTS_PER_MINUTE=10
DAYS_BACK=730
MAX_POSTS=20000

# Date range (since → until). Empty until = today (2026-06-09).
SCRAPE_SINCE=2025-01-01
SCRAPE_UNTIL=

# Tolerance: consecutive out-of-range posts before stopping scroll
# (Facebook feed is not strictly chronological, so tolerate some)
CUTOFF_TOLERANCE=10

# === PROXY (optional) ===
# PROXY_URL=http://user:pass@host:port


# === Bot Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Dashboard / Railway ===
# GROQ_API_KEY=gsk_...            # obligatorio (visión + sentimiento de respaldo)
# DATA_DIR=/data                  # montar volumen persistente de Railway aquí
# MOTOR_SENTIMIENTO=groq          # auto|bert|groq|reglas. Usar "groq" para NO cargar BERT (ahorra RAM en Railway)
# BERT_LOAD_TIMEOUT_S=120
# GROQ_TEXT_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct