{
  "manifest_version": 3,
  "name": "TikTok Scraper Pro",
  "version": "1.0",
  "description": "Extrae todos los datos de TikTok: videos, comentarios, estadísticas",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["*://*.tiktok.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png"
  }
}