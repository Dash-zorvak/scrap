# # Environment
.env
.env.local

# # Streamlit secrets (API keys - NUNCA subir al repo)
.streamlit/secrets.toml

# # Python
venv/
venv_sentiment/
.venv/
__pycache__/
*.pyc
.pytest_cache/

# # IDE
# .vscode/
# .idea/

# # OS
.DS_Store
Thumbs.db

# # Data (bases locales, NUNCA versionar)
data/*.db

# # Outputs (se regeneran desde el dashboard)
outputs/*.json
outputs/*.csv

# # Capturas subidas (temporales, se procesan en memoria y NO se versionan)
data/uploads_tmp/

# # Capturas subidas con datos personales de terceros (rostros, nombres,
# # comentarios de ciudadanos) — NUNCA versionar (ver HA1 en plan maestro)
data/capturas/

# # Logs
*.log

# # Session / Cookies (sensible, NUNCA subir)
cookies.json
tiktok_cookies.json
tiktok_session.json
src/tiktok_session_cookies.json
data/*_cookies.json

# # Checkpoints generados por scripts
*_checkpoint.json
data/*_checkpoint.json

# # DBs huérfanas / efímeras
data/backup.db
data/analytics_cache.db
data/pipeline.db

# # SQLite WAL/SHM (efímeros, no versionar)
data/*.db-shm
data/*.db-wal

# # Purge backups (generados por scripts/purge_out_of_range.py)
data/*.purge_backup_*.db
data/*.backup_*.db

# # Skills / artefactos de agentes de IA (Open Devin y similares)
.od-skills/
**/.od-skills/

# # Analysis JSON (generado por analista externo, no se versiona)
data/analysis.json

# # Backups de analysis.json (generados por analytics/publish.py)
data/analysis.backup_*.json
data/_analysis_backups/

# # Baseline backup de DBs (generado por plan maestro fase 0)
data/_baseline_backup/
*.egg-info/
