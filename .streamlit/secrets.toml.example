# Plantilla de secretos para Streamlit.
# 1) Copia este archivo a: .streamlit/secrets.toml
# 2) Completa tus claves reales.
# 3) NUNCA subas secrets.toml al repositorio (ya esta en .gitignore).
#
# En produccion (Railway), estas variables van en el gestor de secretos del host,
# no en este archivo.

# Clave de Groq (motor de Vision para extraer texto de las capturas)
GROQ_API_KEY = "tu_clave_de_groq_aqui"
