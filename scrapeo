#!/bin/bash
DIR="$(cd "$(dirname "$0")" && pwd)"
source "$DIR/venv/bin/activate"

list_pages() {
    python3 -c "
import json, os
from dotenv import load_dotenv
load_dotenv()
raw = os.getenv('FB_PAGES', '')
if raw:
    try:
        pages = json.loads(raw)
        for i, p in enumerate(pages):
            ident = p.get('id') or p.get('url', '?')
            method = '🔑 Graph API' if 'id' in p else '🌐 Playwright/Deep'
            print(f'  [{i}] {p[\"name\"]} — {method} ({ident})')
        exit(0)
    except: pass
print(f'  [0] {os.getenv(\"FB_PAGE_NAME\", \"?\")} — 🔑 Graph API ({os.getenv(\"FB_PAGE_ID\", \"?\")})')
"
}

run_pages() {
    max="$1"
    search="$2"
    python3 -c "
import json, os, subprocess, sys
from dotenv import load_dotenv
load_dotenv()
raw = os.getenv('FB_PAGES', '')
if raw:
    pages = json.loads(raw)
else:
    pid = os.getenv('FB_PAGE_ID') or ''
    pname = os.getenv('FB_PAGE_NAME') or ''
    purl = os.getenv('FB_PAGE_URL') or ''
    if pid:
        pages = [{'id': pid, 'name': pname, 'url': purl}]
    elif purl:
        pages = [{'url': purl, 'name': pname or purl}]
    else:
        pages = []
max_posts = $max
for i, page in enumerate(pages):
    pname = page.get('name', '?')
    pid = page.get('id', '')
    purl = page.get('url', '')
    print()
    print('='*60)
    print(f'  [{i+1}/{len(pages)}] {pname}')
    if pid:
        print(f'  Modo: Graph API ({pid})')
    elif purl:
        print(f'  Modo: Deep Scraper ({purl})')
    print('='*60)
    if pid:
        r = subprocess.run(
            [sys.executable, '-m', 'src.fb_scraper.bulk_scraper',
             '--phase', 'all', '--max', str(max_posts)],
            env={**os.environ, 'FB_PAGE_ID': pid, 'FB_PAGE_NAME': pname}
        )
        if r.returncode != 0:
            print(f'  [WARN] Error en {pname}, continuando...')
    elif purl:
        r = subprocess.run(
            [sys.executable, '-m', 'src.main', 'deep-scrape',
             '--page-url', purl, '--page-name', pname,
             '--max', str(max_posts)],
            env=os.environ
        )
        if r.returncode != 0:
            print(f'  [WARN] Error en {pname}, continuando...')
    else:
        print(f'  [SKIP] Sin ID ni URL')
search_keyword = os.environ.get('SEARCH_KEYWORD', '$search').strip()
if search_keyword:
    print()
    print('='*60)
    print(f'  🔍 Deep Search: {search_keyword}')
    print('='*60)
    r = subprocess.run(
        [sys.executable, '-m', 'src.main', 'deep-scrape',
         '--search', search_keyword, '--max', str(max_posts), '--headless'],
        env=os.environ
    )
    if r.returncode != 0:
        print(f'  [WARN] Error en deep search, continuando...')
print()
print('--- Dashboard Update ---')
subprocess.run([sys.executable, '-m', 'src.main', 'analyze'])
"
}

case "$1" in
estimate)
    target="${2:-20000}"
    exec python3 "$DIR/src/analyzer/estimation.py" "$target"
    ;;
phase3)
    shift
    exec python3 -m src.main phase3 "$@"
    ;;
full-scrape|bulk-scrape)
    max="${2:-500}"
    search="${3:-${SEARCH_KEYWORD:-}}"
    echo "=== SCRAPE: $max posts por página ==="
    [ -n "$search" ] && echo "  + Deep Search: $search"
    run_pages "$max" "$search"
    ;;
deep-search)
    search="${2:-Jose Chicas}"
    max="${3:-500}"
    echo "=== DEEP SEARCH: $search ($max posts) ==="
    exec python3 -m src.main deep-scrape --search "$search" --max "$max" --headless
    ;;
pages)
    list_pages
    ;;
*)
    exec python3 -m src.main "$@"
    ;;
esac
