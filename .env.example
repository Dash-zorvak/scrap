# === FACEBOOK PAGE ===
FB_PAGE_URL=https://www.facebook.com/SantaAnaAlcaldia
FB_PAGE_NAME=Santa Ana Alcaldía

# === FACEBOOK LOGIN (necesario para Playwright) ===
FB_EMAIL=
FB_PASSWORD=

# === TIKTOK ===
TT_USERNAME=alcaldiasa

# === SCRAPING CONFIG ===
REQUESTS_PER_MINUTE=10
DAYS_BACK=730
MAX_POSTS=20000

# Date range (since → until). Empty until = today (2026-06-09).
SCRAPE_SINCE=2025-01-01
SCRAPE_UNTIL=

# Tolerance: consecutive out-of-range posts before stopping scroll
# (Facebook feed is not strictly chronological, so tolerate some)
CUTOFF_TOLERANCE=10

# === PROXY (optional) ===
# PROXY_URL=http://user:pass@host:port


# === Bot Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=